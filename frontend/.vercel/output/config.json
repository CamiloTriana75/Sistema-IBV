{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "/register",
      "dest": "/register"
    },
    {
      "src": "/recibidor/recepciones",
      "dest": "/recibidor/recepciones"
    },
    {
      "src": "/recibidor/impronta-print",
      "dest": "/recibidor/impronta-print"
    },
    {
      "src": "/recibidor/impronta",
      "dest": "/recibidor/impronta"
    },
    {
      "src": "/recibidor/escaneo",
      "dest": "/recibidor/escaneo"
    },
    {
      "src": "/recibidor",
      "dest": "/recibidor"
    },
    {
      "src": "/porteria",
      "dest": "/porteria"
    },
    {
      "src": "/login",
      "dest": "/login"
    },
    {
      "src": "/inventario/checklist",
      "dest": "/inventario/checklist"
    },
    {
      "src": "/inventario",
      "dest": "/inventario"
    },
    {
      "src": "/despachador/planilla",
      "dest": "/despachador/planilla"
    },
    {
      "src": "/despachador/escaneo",
      "dest": "/despachador/escaneo"
    },
    {
      "src": "/despachador",
      "dest": "/despachador"
    },
    {
      "src": "/api/test",
      "dest": "/api/test"
    },
    {
      "src": "/api/admin/users",
      "dest": "/api/admin/users"
    },
    {
      "src": "/admin/usuarios",
      "dest": "/admin/usuarios"
    },
    {
      "src": "/admin/roles",
      "dest": "/admin/roles"
    },
    {
      "src": "/admin/recepcion",
      "dest": "/admin/recepcion"
    },
    {
      "src": "/admin/notificaciones",
      "dest": "/admin/notificaciones"
    },
    {
      "src": "/admin/inventario",
      "dest": "/admin/inventario"
    },
    {
      "src": "/admin/excepciones",
      "dest": "/admin/excepciones"
    },
    {
      "src": "/admin/estadisticas",
      "dest": "/admin/estadisticas"
    },
    {
      "src": "/admin/despacho",
      "dest": "/admin/despacho"
    },
    {
      "src": "/admin/auditoria",
      "dest": "/admin/auditoria"
    },
    {
      "src": "/admin",
      "dest": "/admin"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/api/admin/users/(?<id>[^/]+)",
      "dest": "/api/admin/users/[id]"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}