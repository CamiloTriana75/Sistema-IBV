[flake8]
# Configuración de Flake8 para Sistema IBV Backend

# Longitud máxima de línea (debe coincidir con black)
max-line-length = 88

# Archivos y directorios a excluir
exclude =
    .git,
    __pycache__,
    */migrations/*,
    */settings.py,
    venv,
    env,
    .venv,
    build,
    dist,
    *.egg-info,
    .tox,
    .pytest_cache,
    node_modules

# Errores a ignorar
ignore =
    # W503: line break before binary operator (conflicto con black)
    W503,
    # E203: whitespace before ':' (conflicto con black)
    E203,
    # E501: line too long (manejado por black)
    E501,
    # W504: line break after binary operator
    W504

# Complejidad ciclomática máxima
max-complexity = 10

# Configuración de plugins
per-file-ignores =
    # Permitir imports de múltiples líneas en __init__.py
    __init__.py: F401, F403
    # Permitir configuraciones de Django en settings
    settings.py: E501
    # Tests
    */tests/*.py: F401, F841

# Formato de salida
format = pylint
show-source = True
statistics = True
count = True
